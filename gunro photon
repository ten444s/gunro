local flint_busy = false
local FLINT_GUN = "[Flintlock]"
local FLINT_CANCEL = "[Knife]"

local function flint_sequence()
    local gun_slot   = find_gun_slot(FLINT_GUN)
    local knife_slot = find_gun_slot(FLINT_CANCEL)
    if not gun_slot then
        log.add("[Flint] " .. FLINT_GUN .. " not on hotbar", color(1, 0.6, 0, 1))
        flint_busy = false
        return
    end
    if not knife_slot then
        log.add("[Flint] " .. FLINT_CANCEL .. " not on hotbar", color(1, 0.6, 0, 1))
        flint_busy = false
        return
    end

    local step = math.floor(flint_step:get_value())

    input.simulate_mouse_down(MOUSE1)
    wait(step)
    input.simulate_mouse_up(MOUSE1)
    wait(step)
    input.simulate_press(SLOT_KEYS[gun_slot])
    input.simulate_mouse_down(MOUSE1)
    wait(step)
    input.simulate_mouse_up(MOUSE1)
    wait(step)
    input.simulate_press(SLOT_KEYS[knife_slot])

    wait(1200)
    flint_busy = false
end

local rf_holding = false
local prev_flint_key = false
local prev_cycle_key = false

spawn(function()
    while true do
        if can_act() then
            shot_watch()

            local cycle_key = cycle_manual_bind:get_state()
            if cycle_enable:get_value() and (not require_tb_key:get_value()) and cycle_key and not prev_cycle_key and not cycle_busy then
                start_cycle(true)
            end
            prev_cycle_key = cycle_key

            local flint_key = flint_bind:get_state()
            if flint_enable:get_value() and flint_key and not prev_flint_key and not flint_busy then
                flint_busy = true
                spawn(flint_sequence)
            end
            prev_flint_key = flint_key

            if rf_enable:get_value() and rf_bind:get_state() then
                input.simulate_mouse_down(MOUSE1)
                rf_holding = true
                wait(math.floor(rf_interval:get_value()))
            else
                if rf_holding then
                    input.simulate_mouse_up(MOUSE1)
                    rf_holding = false
                end
                wait(10)
            end
        else
            if rf_holding then
                input.simulate_mouse_up(MOUSE1)
                rf_holding = false
            end
            prev_cycle_key = false
            prev_flint_key = false
            wait(50)
        end
    end
end)


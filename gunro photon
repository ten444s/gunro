local rf_bind     = MENU:add_keybind("RF Hold", 0x04)
local rf_interval = MENU:add_slider("Click Interval (ms)", 1, 50, 1)

local hotbar_cache = nil

local function get_hotbar()
    if hotbar_cache and hotbar_cache:isvalid() then
        return hotbar_cache
    end
    local coregui = game:get_service("CoreGui")
    if not coregui:isvalid() then return nil end
    local robloxgui = coregui:find_first_child("RobloxGui")
    if not robloxgui:isvalid() then return nil end
    local backpack = robloxgui:find_first_child("Backpack")
    if not backpack:isvalid() then return nil end
    local hb = backpack:find_first_child("Hotbar")
    if not hb:isvalid() then return nil end
    hotbar_cache = hb
    return hb
end

local function find_gun_slot(gunname)
    local hb = get_hotbar()
    if not hb then return nil end
    for i = 1, 10 do
        local btn = hb:find_first_child(tostring(i))
        if btn:isvalid() then
            local lbl = btn:find_first_child("ToolName")
            if lbl:isvalid() and lbl:get_label_text() == gunname then
                return i
            end
        end
    end
    return nil
end

local function get_character()
    local lp = PlayersService.local_player
    if not lp:isvalid() then return nil end
    local char = lp.character
    if not char:isvalid() then return nil end
    return char
end

local function get_equipped_tool_name()
    local char = get_character()
    if not char then return nil end
    for _, v in pairs(char:get_children()) do
        if v:isvalid() and v.class_name == "Tool" then
            return v.name
        end
    end
    return nil
end

local function is_equipped(gunname)
    local char = get_character()
    if not char then return false end
    local tool = char:find_first_child(gunname)
    return tool:isvalid()
end

local function equip_gun(gunname)
    if skip_equipped:get_value() and is_equipped(gunname) then
        return true
    end
    local slot = find_gun_slot(gunname)
    if not slot then
        return false
    end
    input.simulate_press(SLOT_KEYS[slot])
    return true
end

local function scan_hotbar_debug()
    local hb = get_hotbar()
    if not hb then
        log.add("[GunMacros] Hotbar UI not found!", color(1, 0, 0, 1))
        return
    end
    for i = 1, 10 do
        local btn = hb:find_first_child(tostring(i))
        if btn:isvalid() then
            local lbl = btn:find_first_child("ToolName")
            if lbl:isvalid() then
                local txt = lbl:get_label_text()
                if txt ~= "" then
                    log.add("[GunMacros] Slot " .. tostring(i) .. " = " .. txt, color(0, 1, 1, 1))
                end
            end
        end
    end
end

MENU:add_button("Scan Hotbar (log slots)", scan_hotbar_debug)

local function can_act()
    return is_gamefocused() and not menu_active()
end

local cycle_busy = false
local cycle_start_i = 1
local cycle_fire_all = false

local function cycle_run()
    local shot_d = math.floor(shot_delay:get_value())
    local len = math.floor(seq_len:get_value())
    local combos = { cycle_gun1, cycle_gun2, cycle_gun3 }
    local equips = { gun1_equip, gun2_equip, gun3_equip }

    local idx = cycle_start_i

    if cycle_fire_all then
        local name = combos[idx]:get_text()
        if equip_gun(name) then
            wait(math.floor(equips[idx]:get_value()))
            input.simulate_mouse_click(MOUSE1)
            wait(shot_d)
        else
            log.add("[Cycle] " .. name .. " not on hotbar, skipped", color(1, 0.6, 0, 1))
        end
    else
        wait(shot_d)
    end

    local fired = 1
    while fired < len do
        idx = idx % len + 1
        local name = combos[idx]:get_text()
        if equip_gun(name) then
            wait(math.floor(equips[idx]:get_value()))
            input.simulate_mouse_click(MOUSE1)
            wait(shot_d)
        else
            log.add("[Cycle] " .. name .. " not on hotbar, skipped", color(1, 0.6, 0, 1))
        end
        fired = fired + 1
    end

    wait(math.floor(cycle_cooldown:get_value()))
    cycle_busy = false
end

local function start_cycle(force_all)
    if cycle_busy or not cycle_enable:get_value() or not can_act() then
        return
    end

    if force_all then
        cycle_start_i = 1
        cycle_fire_all = true
    else
        local held = get_equipped_tool_name()
        local len = math.floor(seq_len:get_value())
        local names = { cycle_gun1:get_text(), cycle_gun2:get_text(), cycle_gun3:get_text() }

        local match_i = nil
        for i = 1, len do
            if names[i] == held then
                match_i = i
                break
            end
        end

        if match_i then
            cycle_start_i = match_i
            cycle_fire_all = false
        else
            cycle_start_i = 1
            cycle_fire_all = true
        end
    end

    cycle_busy = true
    spawn(cycle_run)
end

local last_ammo_gun = nil
local last_ammo = nil

local function shot_watch()
    if cycle_busy or not cycle_enable:get_value() then
        last_ammo_gun = nil
        return
    end

    if not require_tb_key:get_value() then
        last_ammo_gun = nil
        return
    end
    if not keybind_active("triggerbot") then
        last_ammo_gun = nil
        return
    end

    local char = get_character()
    if not char then
        last_ammo_gun = nil
        return
    end

    local len = math.floor(seq_len:get_value())
    local names = { cycle_gun1:get_text(), cycle_gun2:get_text(), cycle_gun3:get_text() }
    local match_i = nil
    local tool = nil
    for i = 1, len do
        local t = char:find_first_child(names[i])
        if t:isvalid() then
            match_i = i
            tool = t
            break
        end
    end
    if not match_i then
        last_ammo_gun = nil
        return
    end

    local held = names[match_i]
    local a = tool:find_first_child("Ammo")
    if not a:isvalid() then return end
    local ammo = a:get_value_int()
    if ammo == nil then return end

    if last_ammo_gun == held and last_ammo ~= nil and ammo < last_ammo then
        last_ammo_gun = nil
        cycle_start_i = match_i
        cycle_fire_all = false
        cycle_busy = true
        spawn(cycle_run)
        return
    end

    last_ammo_gun = held
    last_ammo = ammo
end


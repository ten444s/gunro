local cycle_gun2     = MENU:add_combo("Gun 2", GUNS, 0)
local gun2_equip     = MENU:add_slider("Equip delay 2 (ms)", 0, 300, 2)
local cycle_gun3     = MENU:add_combo("Gun 3", GUNS, 5)
local gun3_equip     = MENU:add_slider("Equip delay 3 (ms)", 0, 300, 2)
local skip_equipped  = MENU:add_checkbox("Skip Equipped", true)
